<ui:FluentWindow x:Class="VisionInspection.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="板件缺件视觉检测系统"
    Height="760" Width="1280"
    MinHeight="640" MinWidth="1040"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="板件缺件视觉检测系统">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="ScanObject24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Border Grid.Column="0" Background="#14000000" Margin="8,0,0,8" CornerRadius="10" Padding="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="6,6,6,16">
                        <TextBlock Text="板件缺件检测" FontSize="17" FontWeight="Bold" />
                        <TextBlock Text="Vision Inspection" FontSize="11" Opacity="0.6" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="6,12,6,4">
                        <Border Height="1" Background="#22FFFFFF" Margin="0,0,0,8" />
                        <TextBlock Text="v1.0 · .NET Framework 4.8" FontSize="10" Opacity="0.5" />
                    </StackPanel>

                    <StackPanel>
                        <ui:Button Command="{Binding NavigateToRunCommand}"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                   Appearance="Secondary" Margin="0,0,0,6" Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Play24" Margin="0,0,10,0" />
                                <TextBlock Text="运行监视" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding NavigateToRecipesCommand}"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                   Appearance="Secondary" Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Grid24" Margin="0,0,10,0" />
                                <TextBlock Text="配方管理" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding NavigateToSettingsCommand}"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                   Appearance="Secondary" Margin="0,6,0,0" Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" Margin="0,0,10,0" />
                                <TextBlock Text="系统设置" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentPresenter Grid.Column="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
