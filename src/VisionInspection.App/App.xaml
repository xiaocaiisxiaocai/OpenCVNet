<Application x:Class="VisionInspection.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:VisionInspection.App.ViewModels"
             xmlns:views="clr-namespace:VisionInspection.App.Views"
             xmlns:conv="clr-namespace:VisionInspection.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- VM → View 映射（严格 MVVM，页面以 DataTemplate 呈现） -->
            <DataTemplate DataType="{x:Type vm:RecipeManagementViewModel}">
                <views:RecipeManagementView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RunViewModel}">
                <views:RunView />
            </DataTemplate>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <conv:DetectionMethodNameConverter x:Key="MethodName" />
            <conv:PartPolarityNameConverter x:Key="PolarityName" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
